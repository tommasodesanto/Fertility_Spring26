# Named Codex worker profiles.  Values are consumed by scripts/codex-worker.sh.
# Keep model selection and reasoning effort explicit for reproducible delegation.

EXPLORER_FAST_MODEL="gpt-5.6-terra"
EXPLORER_FAST_REASONING_EFFORT="low"
EXPLORER_FAST_CONTEXT_MODE="minimal"
EXPLORER_FAST_TIME_LIMIT_MIN="10"

MECHANIC_FAST_MODEL="gpt-5.3-codex-spark"
MECHANIC_FAST_REASONING_EFFORT="low"
MECHANIC_FAST_CONTEXT_MODE="minimal"
MECHANIC_FAST_TIME_LIMIT_MIN="10"

WORKER_FAST_MODEL="gpt-5.6-terra"
WORKER_FAST_REASONING_EFFORT="medium"
WORKER_FAST_CONTEXT_MODE="full"
WORKER_FAST_TIME_LIMIT_MIN="30"

REVIEWER_STRONG_MODEL="gpt-5.6-terra"
REVIEWER_STRONG_REASONING_EFFORT="high"
REVIEWER_STRONG_CONTEXT_MODE="full"
REVIEWER_STRONG_TIME_LIMIT_MIN="20"
